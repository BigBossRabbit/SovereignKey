    def _bt_refresh_status(self):
        bt_on  = is_bt_active()
        svc_on = is_service_active("spawn-bitchat")
        self._bt_hw_badge.set_state("online" if bt_on else "offline",
                                    "Active" if bt_on else "Not detected")
        self._bt_svc_badge.set_state("online" if svc_on else "offline",
                                     "Running" if svc_on else "Stopped")

    def _bt_enable(self, btn):
        run_cmd_async("sudo hciconfig hci0 up 2>/dev/null; sudo rfkill unblock bluetooth 2>/dev/null; echo done",
                      lambda o, ok: (self._bt_refresh_status(), self._show_toast("Bluetooth enabled" if ok else "No Bluetooth hardware found")))

    def _bt_start(self, btn):
        btn.set_sensitive(False)
        def done(out, ok):
            btn.set_sensitive(True)
            self._bt_refresh_status()
            self._show_toast("BitChat started!" if ok else f"Error: {out[:60]}")
        run_cmd_async("sudo systemctl start spawn-bitchat 2>&1", done)

    def _bt_scan(self, btn):
        btn.set_sensitive(False)
        btn.set_label("Scanning (10s)…")
        self._show_toast("Scanning for nearby devices…")

        for child in self._bt_device_list.get_children():
            self._bt_device_list.remove(child)

        def done(out, ok):
            btn.set_sensitive(True)
            btn.set_label("🔍  Scan for Devices")
            if out:
                lines = [l.strip() for l in out.splitlines() if l.strip() and "Scanning" not in l]
                for line in lines:
                    # Parse "AA:BB:CC:DD:EE:FF  DeviceName"
                    row = Gtk.ListBoxRow()
                    row_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
                    lbl = Gtk.Label(label=f"  ◆  {line}")
                    lbl.set_xalign(0); lbl.set_margin_top(4); lbl.set_margin_bottom(4)
                    row_box.pack_start(lbl, True, True, 0)
                    # Extract BT address for auto-fill
                    addr_match = re.search(r"([0-9A-F:]{17})", line, re.I)
                    if addr_match:
                        addr = addr_match.group(1)
                        use_btn = Gtk.Button(label="Select")
                        use_btn.get_style_context().add_class("btn-secondary")
                        use_btn.connect("clicked", lambda b, a=addr: self._bt_target_entry.set_text(a))
                        row_box.pack_start(use_btn, False, False, 8)
                    row.add(row_box)
                    self._bt_device_list.add(row)
                self._bt_device_list.show_all()
                self._show_toast(f"Found {len(lines)} device(s)")
            else:
                row = Gtk.ListBoxRow()
                lbl = Gtk.Label(label="  No devices found nearby.")
                lbl.get_style_context().add_class("card-sub"); lbl.set_xalign(0)
                row.add(lbl); self._bt_device_list.add(row)
                self._bt_device_list.show_all()
                self._show_toast("No devices found.")

        run_cmd_async("sudo hcitool scan 2>/dev/null || bluetoothctl devices 2>/dev/null", done, timeout=15)

    def _bt_send(self, widget):
        target = self._bt_target_entry.get_text().strip()
        msg    = self._bt_msg_entry.get_text().strip()
        if not target: self._show_toast("Enter a target address first."); return
        if not msg:    self._show_toast("Enter a message first."); return
        # Validate BT address format
        if not re.match(r"^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$", target):
            self._show_toast("Invalid Bluetooth address format."); return
        msg_safe    = msg.replace("'", "'\\''")
        target_safe = target.replace("'", "")
        self._bt_send_btn.set_sensitive(False)
        def done(out, ok):
            self._bt_send_btn.set_sensitive(True)
            if ok:
                self._bt_msg_entry.set_text("")
                self._show_toast("Message sent!")
            else:
                self._show_toast(f"Send failed: {out[:60]}")
        run_cmd_async(f"{SPAWN_COMMS} bitchat send '{target_safe}' '{msg_safe}'", done)

