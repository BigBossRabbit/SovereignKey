        s = Gtk.Label(label="Bluetooth mesh messaging. No internet. No infrastructure. Just nearby devices.")
        s.set_name("page-sub"); s.set_xalign(0)
        box.pack_start(t, False, False, 0)
        box.pack_start(s, False, False, 4)

        # Status card
        status_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        status_card.get_style_context().add_class("card")

        status_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
