        box.pack_start(_gap(12), False, False, 0)

        # Discovered devices
        dev_hdr = Gtk.Label(label="NEARBY SPAWNOS DEVICES")
        dev_hdr.get_style_context().add_class("section-header"); dev_hdr.set_xalign(0)
        box.pack_start(dev_hdr, False, False, 0)

