        self._bt_device_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        empty_row = Gtk.ListBoxRow()
        self._bt_empty_lbl = Gtk.Label(label="  No devices found yet. Click Scan to discover nearby devices.")
        self._bt_empty_lbl.get_style_context().add_class("card-sub")
