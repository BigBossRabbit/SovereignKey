    # ─────────────────────────────────────────────────────────────────────────
    def _page_bitchat(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_name("content")
        box.set_margin_start(32); box.set_margin_end(32)
        box.set_margin_top(28);   box.set_margin_bottom(28)

