def run_cmd(cmd, timeout=15):
    """Run a shell command, return (stdout, stderr, returncode)."""
    try:
        r = subprocess.run(
            cmd, shell=True, capture_output=True,
            text=True, timeout=timeout
        )
        return r.stdout.strip(), r.stderr.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", "timeout", 1
    except Exception as e:
        return "", str(e), 1


def run_cmd_async(cmd, callback, timeout=20):
    """Run a shell command in a background thread, call callback(stdout, ok) on GTK main thread."""
    def worker():
        out, err, rc = run_cmd(cmd, timeout)
        GLib.idle_add(callback, out if rc == 0 else err, rc == 0)
    threading.Thread(target=worker, daemon=True).start()


def is_service_active(name):
    _, _, rc = run_cmd(f"systemctl is-active --quiet {name}")
    return rc == 0


def get_lan_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return "unknown"


def is_bt_active():
    out, _, _ = run_cmd("hciconfig 2>/dev/null")
    return "UP RUNNING" in out


def get_nostr_keys():
    keys = []
    if NOSTR_KEYS.exists():
        for f in NOSTR_KEYS.glob("*.nostr.gpg"):
            keys.append(f.stem.replace(".nostr", ""))
    return keys


def get_nostr_peers():
    if PEERS_FILE.exists():
        try:
            return json.loads(PEERS_FILE.read_text())
        except Exception:
            pass
    return []


# ─── Main Window ──────────────────────────────────────────────────────────────
class SpawnCommsHub(Gtk.ApplicationWindow):

    def __init__(self, app):
        super().__init__(application=app, title="SpawnOS — Comms Hub")
        self.set_default_size(1060, 680)
        self.set_resizable(True)

        # Apply CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        self._current_page = "overview"
        self._build_layout()
        self._show_page("overview")

        # Live status refresh every 4 seconds
        GLib.timeout_add(4000, self._refresh_status)
        GLib.idle_add(self._refresh_status)

    # ── Layout ────────────────────────────────────────────────────────────────
    def _build_layout(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.add(root)

        # Top bar
        self._topbar = self._build_topbar()
        root.pack_start(self._topbar, False, False, 0)

        sep = Gtk.Separator()
        root.pack_start(sep, False, False, 0)

        body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.pack_start(body, True, True, 0)

        # Sidebar
        self._sidebar = self._build_sidebar()
        body.pack_start(self._sidebar, False, False, 0)

        sep2 = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        body.pack_start(sep2, False, False, 0)

        # Content stack
        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self._stack.set_transition_duration(120)
        self._stack.get_style_context().add_class("content")

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.add(self._stack)
        body.pack_start(scroll, True, True, 0)

        # Build all pages
        self._stack.add_named(self._page_overview(),    "overview")
        self._stack.add_named(self._page_nostr(),       "nostr")
        self._stack.add_named(self._page_bitchat(),     "bitchat")
        self._stack.add_named(self._page_whitenoise(),  "whitenoise")
        self._stack.add_named(self._page_pair(),        "pair")
        self._stack.add_named(self._page_settings(),    "settings")

    def _build_topbar(self):
        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        bar.set_name("topbar")
        bar.set_spacing(12)

        self._device_label = Gtk.Label()
        self._device_label.set_name("device-info")
        self._device_label.set_markup(f"<span foreground='#6b7280'>Loading...</span>")
        bar.pack_start(self._device_label, True, True, 0)

        self._tor_badge = Gtk.Label(label="● TOR")
        self._tor_badge.set_name("tor-badge")
        self._tor_badge.get_style_context().add_class("tor-off")
        bar.pack_end(self._tor_badge, False, False, 0)

        return bar

    def _build_sidebar(self):
        sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        sidebar.set_name("sidebar")

        # Logo
        logo_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        logo_box.set_name("sidebar-logo")
        t = Gtk.Label(label="SPAWNOS")
        t.set_name("logo-title")
        t.set_xalign(0)
        s = Gtk.Label(label="COMMS HUB")
        s.set_name("logo-sub")
        s.set_xalign(0)
        logo_box.pack_start(t, False, False, 0)
        logo_box.pack_start(s, False, False, 0)
        sidebar.pack_start(logo_box, False, False, 0)

        sep = Gtk.Separator()
        sidebar.pack_start(sep, False, False, 0)

        # Nav
        nav_items = [
            ("overview",   "◉  Overview"),
            ("nostr",      "⬡  Nostr"),
            ("bitchat",    "⬡  BitChat"),
            ("whitenoise", "⬡  WhiteNoise"),
            ("pair",       "⊕  Pair Devices"),
            ("settings",   "⚙  Settings"),
        ]
        self._nav_btns = {}
        for page_id, label in nav_items:
            btn = Gtk.Button(label=label)
            btn.get_style_context().add_class("nav-btn")
            btn.set_relief(Gtk.ReliefStyle.NONE)
            btn.connect("clicked", self._on_nav_click, page_id)
            sidebar.pack_start(btn, False, False, 0)
            self._nav_btns[page_id] = btn

        # Spacer
        sidebar.pack_start(Gtk.Box(), True, True, 0)

        # Version
        ver = Gtk.Label(label="SpawnOS v1.0.0")
        ver.set_xalign(0.5)
        ver.set_margin_bottom(16)
        ver.get_style_context().add_class("card-sub")
        sidebar.pack_start(ver, False, False, 0)

        return sidebar

    def _on_nav_click(self, btn, page_id):
        self._show_page(page_id)

    def _show_page(self, page_id):
        self._current_page = page_id
        self._stack.set_visible_child_name(page_id)
        for pid, btn in self._nav_btns.items():
            ctx = btn.get_style_context()
            if pid == page_id:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

    # ── Status Refresh ────────────────────────────────────────────────────────
    def _refresh_status(self):
        # Topbar
        ip   = get_lan_ip()
        name = os.uname().nodename
        self._device_label.set_markup(
            f"<span foreground='#9ca3af'>{name}</span>"
            f"<span foreground='#4b5563'>  ·  </span>"
            f"<span foreground='#6d28d9'>{ip}</span>"
        )
        tor_on = is_service_active("tor")
        self._tor_badge.set_label("● TOR" if tor_on else "○ TOR")
        ctx = self._tor_badge.get_style_context()
        ctx.remove_class("tor-on")
        ctx.remove_class("tor-off")
        ctx.add_class("tor-on" if tor_on else "tor-off")

        # Overview cards
        if hasattr(self, "_ov_cards"):
            self._ov_cards["nostr"].update(
                is_service_active("spawn-nostr-relay"),
                f"Relay at ws://{ip}:7777"
            )
            self._ov_cards["bitchat"].update(
                is_bt_active(),
                "Bluetooth mesh ready" if is_bt_active() else "No Bluetooth detected"
            )
            self._ov_cards["whitenoise"].update(
                is_service_active("spawn-whitenoise"),
                "libp2p mesh active" if is_service_active("spawn-whitenoise") else "Daemon stopped"
            )

        return True  # keep repeating

    # ─────────────────────────────────────────────────────────────────────────
    # PAGE: OVERVIEW
    # ─────────────────────────────────────────────────────────────────────────
    def _page_overview(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_name("content")
        box.set_margin_start(32); box.set_margin_end(32)
        box.set_margin_top(28);   box.set_margin_bottom(28)

        t = Gtk.Label(label="Communications Overview")
        t.set_name("page-title"); t.set_xalign(0)
        s = Gtk.Label(label="All three comms layers run offline between SpawnOS devices.")
        s.set_name("page-sub"); s.set_xalign(0)
        box.pack_start(t, False, False, 0)
        box.pack_start(s, False, False, 4)

        # Three protocol cards
        cards_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        cards_box.set_margin_top(8)
        box.pack_start(cards_box, False, True, 0)

        self._ov_cards = {}
        protocols = [
            ("nostr",       "⬡",  "Nostr",       "Decentralized messaging\nLocal relay on LAN",  "nostr"),
            ("bitchat",     "⬡",  "BitChat",      "Bluetooth mesh\nNo internet needed",          "bitchat"),
            ("whitenoise",  "⬡",  "WhiteNoise",   "libp2p anonymous mesh\nmDNS LAN discovery",   "whitenoise"),
        ]
        for page_id, icon, name, desc, service in protocols:
            card = OverviewCard(icon, name, desc, page_id, self._show_page)
            self._ov_cards[page_id] = card
            cards_box.pack_start(card, True, True, 0)

        # Quick actions
        sep = Gtk.Separator(); sep.set_margin_top(24); sep.set_margin_bottom(16)
        box.pack_start(sep, False, False, 0)

        qa_label = Gtk.Label(label="QUICK ACTIONS")
        qa_label.get_style_context().add_class("section-header")
        qa_label.set_xalign(0)
        box.pack_start(qa_label, False, False, 0)

        qa_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.pack_start(qa_row, False, False, 0)

        start_all = Gtk.Button(label="▶  Start All Services")
        start_all.get_style_context().add_class("btn-primary")
        start_all.connect("clicked", self._start_all_services)
        qa_row.pack_start(start_all, False, False, 0)

        pair_btn = Gtk.Button(label="⊕  Pair a Device")
        pair_btn.get_style_context().add_class("btn-secondary")
        pair_btn.connect("clicked", lambda b: self._show_page("pair"))
        qa_row.pack_start(pair_btn, False, False, 0)

        # System info box
        sep2 = Gtk.Separator(); sep2.set_margin_top(24); sep2.set_margin_bottom(16)
        box.pack_start(sep2, False, False, 0)

        info_label = Gtk.Label(label="OFFLINE MESH CAPABILITY")
        info_label.get_style_context().add_class("section-header")
        info_label.set_xalign(0)
        box.pack_start(info_label, False, False, 0)

        info_card = Gtk.Box()
        info_card.get_style_context().add_class("card")
        info_card.set_orientation(Gtk.Orientation.VERTICAL)
        info_card.set_spacing(6)

        rows = [
            ("⬡", "BitChat",    "Bluetooth only — works with zero infrastructure, even without WiFi"),
            ("⬡", "Nostr",      "LAN relay mesh — SpawnOS devices sync via each other's local relay"),
            ("⬡", "WhiteNoise", "mDNS mesh — auto-discovers other SpawnOS devices on the same network"),
        ]
        for icon, name, note in rows:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            ico = Gtk.Label(label=icon); ico.get_style_context().add_class("dot-gray")
            nm  = Gtk.Label(label=name); nm.set_markup(f"<b>{name}</b>"); nm.set_size_request(90, -1); nm.set_xalign(0)
            nt  = Gtk.Label(label=note); nt.get_style_context().add_class("card-sub"); nt.set_xalign(0)
            row.pack_start(ico, False, False, 0)
            row.pack_start(nm,  False, False, 0)
            row.pack_start(nt,  True,  True,  0)
            info_card.pack_start(row, False, False, 0)

        box.pack_start(info_card, False, True, 0)
        return box

    def _start_all_services(self, btn):
        btn.set_sensitive(False)
        btn.set_label("Starting…")
        def done(out, ok):
            btn.set_sensitive(True)
            btn.set_label("▶  Start All Services")
            self._show_toast("All services started." if ok else "Partial start — check logs.")
        run_cmd_async(
            "sudo systemctl start spawn-nostr-relay spawn-bitchat spawn-whitenoise 2>&1",
            done
        )

    # ─────────────────────────────────────────────────────────────────────────
    # PAGE: NOSTR
    # ─────────────────────────────────────────────────────────────────────────
    def _page_nostr(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_name("content")
        box.set_margin_start(32); box.set_margin_end(32)
        box.set_margin_top(28);   box.set_margin_bottom(28)

        t = Gtk.Label(label="Nostr")
        t.set_name("page-title"); t.set_xalign(0)
        s = Gtk.Label(label="Decentralized messaging. Your device runs its own relay on port 7777.")
        s.set_name("page-sub"); s.set_xalign(0)
        box.pack_start(t, False, False, 0)
        box.pack_start(s, False, False, 4)

        # Two columns
        cols = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=20)
        box.pack_start(cols, True, True, 0)

        # LEFT: Relay + Identities
        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        left.set_size_request(340, -1)
        cols.pack_start(left, False, False, 0)

        # Relay card
        relay_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        relay_card.get_style_context().add_class("card")

        relay_title = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        rt = Gtk.Label(label="Local Relay"); rt.get_style_context().add_class("card-title"); rt.set_xalign(0)
        self._nostr_relay_badge = StatusBadge("Checking…", "warn")
        relay_title.pack_start(rt, True, True, 0)
        relay_title.pack_start(self._nostr_relay_badge, False, False, 0)
        relay_card.pack_start(relay_title, False, False, 0)

        self._nostr_relay_url = Gtk.Label(label="")
        self._nostr_relay_url.get_style_context().add_class("card-sub")
        self._nostr_relay_url.set_xalign(0)
        self._nostr_relay_url.set_selectable(True)
        relay_card.pack_start(self._nostr_relay_url, False, False, 0)

        relay_btns = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        relay_start = Gtk.Button(label="Start Relay")
        relay_start.get_style_context().add_class("btn-success")
        relay_start.connect("clicked", self._nostr_relay_start)
        relay_stop = Gtk.Button(label="Stop")
        relay_stop.get_style_context().add_class("btn-danger")
        relay_stop.connect("clicked", self._nostr_relay_stop)
        relay_btns.pack_start(relay_start, False, False, 0)
        relay_btns.pack_start(relay_stop,  False, False, 0)
        relay_card.pack_start(relay_btns, False, False, 0)
        left.pack_start(relay_card, False, False, 0)
        left.pack_start(_gap(12), False, False, 0)

        # Identities card
        id_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        id_card.get_style_context().add_class("card")

        id_header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        it = Gtk.Label(label="Identities"); it.get_style_context().add_class("card-title"); it.set_xalign(0)
        new_id_btn = Gtk.Button(label="+ New")
        new_id_btn.get_style_context().add_class("btn-primary")
        new_id_btn.connect("clicked", self._nostr_new_identity)
        id_header.pack_start(it, True, True, 0)
        id_header.pack_start(new_id_btn, False, False, 0)
        id_card.pack_start(id_header, False, False, 0)

        self._nostr_id_list = Gtk.ListBox()
        self._nostr_id_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        id_card.pack_start(self._nostr_id_list, True, True, 0)

        left.pack_start(id_card, True, True, 0)

        # RIGHT: Peers + Publish
        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        cols.pack_start(right, True, True, 0)

        # Peers card
        peers_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        peers_card.get_style_context().add_class("card")

        peers_header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        pt = Gtk.Label(label="Connected Relays")
        pt.get_style_context().add_class("card-title"); pt.set_xalign(0)
        add_relay_btn = Gtk.Button(label="+ Add Relay")
        add_relay_btn.get_style_context().add_class("btn-secondary")
        add_relay_btn.connect("clicked", self._nostr_add_relay_dialog)
        peers_header.pack_start(pt, True, True, 0)
        peers_header.pack_start(add_relay_btn, False, False, 0)
        peers_card.pack_start(peers_header, False, False, 0)

        self._nostr_peers_list = Gtk.ListBox()
        peers_sw = Gtk.ScrolledWindow()
        peers_sw.set_min_content_height(120)
        peers_sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        peers_sw.add(self._nostr_peers_list)
        peers_card.pack_start(peers_sw, True, True, 0)
        right.pack_start(peers_card, False, True, 0)
        right.pack_start(_gap(12), False, False, 0)

        # Publish card
        pub_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        pub_card.get_style_context().add_class("card")

        pub_title = Gtk.Label(label="Publish a Note")
        pub_title.get_style_context().add_class("card-title"); pub_title.set_xalign(0)
        pub_card.pack_start(pub_title, False, False, 0)

        self._nostr_msg_entry = Gtk.TextView()
        self._nostr_msg_entry.set_wrap_mode(Gtk.WrapMode.WORD)
        self._nostr_msg_entry.set_size_request(-1, 80)
        self._nostr_msg_entry.set_name("log-view")
        self._nostr_msg_entry.get_buffer().set_text("What's on your mind?")
        pub_card.pack_start(self._nostr_msg_entry, False, False, 0)

        pub_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._nostr_pub_btn = Gtk.Button(label="Publish")
        self._nostr_pub_btn.get_style_context().add_class("btn-primary")
        self._nostr_pub_btn.connect("clicked", self._nostr_publish)
        pub_row.pack_end(self._nostr_pub_btn, False, False, 0)
        pub_card.pack_start(pub_row, False, False, 0)

        self._nostr_pub_status = Gtk.Label(label="")
        self._nostr_pub_status.get_style_context().add_class("card-sub")
        self._nostr_pub_status.set_xalign(0)
        pub_card.pack_start(self._nostr_pub_status, False, False, 0)
        right.pack_start(pub_card, False, True, 0)

        # Load data
        self._nostr_refresh()
        return box

    def _nostr_refresh(self):
        # Relay status
        relay_on = is_service_active("spawn-nostr-relay")
        ip = get_lan_ip()
        self._nostr_relay_badge.set_state("online" if relay_on else "offline",
                                          "Running" if relay_on else "Stopped")
        self._nostr_relay_url.set_text(f"ws://{ip}:7777  (share with other SpawnOS devices)" if relay_on else "Start relay to share with other devices")

        # Identities
        for child in self._nostr_id_list.get_children():
            self._nostr_id_list.remove(child)
        keys = get_nostr_keys()
        if keys:
            for k in keys:
                row = Gtk.ListBoxRow()
                lbl = Gtk.Label(label=f"  ◆  {k}")
                lbl.set_xalign(0); lbl.set_margin_top(4); lbl.set_margin_bottom(4)
                row.add(lbl); self._nostr_id_list.add(row)
        else:
            row = Gtk.ListBoxRow()
            lbl = Gtk.Label(label="  No identities yet. Click + New.")
            lbl.get_style_context().add_class("card-sub"); lbl.set_xalign(0)
            row.add(lbl); self._nostr_id_list.add(row)
        self._nostr_id_list.show_all()

        # Peers
        for child in self._nostr_peers_list.get_children():
            self._nostr_peers_list.remove(child)
        peers = get_nostr_peers()
        for p in peers:
            row = Gtk.ListBoxRow()
            lbl = Gtk.Label(label=f"  ⬡  {p}")
            lbl.set_xalign(0); lbl.set_margin_top(4); lbl.set_margin_bottom(4)
            row.add(lbl); self._nostr_peers_list.add(row)
        if not peers:
            row = Gtk.ListBoxRow()
            lbl = Gtk.Label(label="  No relays. Add a SpawnOS device IP or public relay.")
            lbl.get_style_context().add_class("card-sub"); lbl.set_xalign(0)
            row.add(lbl); self._nostr_peers_list.add(row)
        self._nostr_peers_list.show_all()

    def _nostr_relay_start(self, btn):
        btn.set_sensitive(False)
        def done(out, ok):
            btn.set_sensitive(True)
            self._nostr_refresh()
            self._show_toast("Relay started!" if ok else f"Error: {out}")
        run_cmd_async("sudo systemctl start spawn-nostr-relay 2>&1", done)

    def _nostr_relay_stop(self, btn):
        run_cmd_async("sudo systemctl stop spawn-nostr-relay 2>&1",
                      lambda o, ok: (self._nostr_refresh(), self._show_toast("Relay stopped.")))

    def _nostr_new_identity(self, btn):
        dlg = Gtk.Dialog(title="New Nostr Identity", parent=self, modal=True)
        dlg.set_default_size(380, 150)
        ca = dlg.get_content_area()
        ca.set_spacing(12); ca.set_margin_start(20); ca.set_margin_end(20)
        ca.set_margin_top(20); ca.set_margin_bottom(20)

        lbl = Gtk.Label(label="Identity name (e.g. 'main', 'work', 'anon'):")
        lbl.set_xalign(0); ca.pack_start(lbl, False, False, 0)
        entry = Gtk.Entry(); entry.set_placeholder_text("main")
        ca.pack_start(entry, False, False, 0)

        dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dlg.add_button("Create", Gtk.ResponseType.OK)
        dlg.set_default_response(Gtk.ResponseType.OK)
        entry.connect("activate", lambda e: dlg.response(Gtk.ResponseType.OK))
        ca.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            name = entry.get_text().strip() or "default"
            dlg.destroy()
            # Sanitize name
            name = re.sub(r"[^a-zA-Z0-9_\-]", "", name)[:32] or "default"
            self._show_toast(f"Creating identity '{name}'…")
            def done(out, ok):
                self._nostr_refresh()
                self._show_toast(f"Identity '{name}' created!" if ok else f"Error: {out[:80]}")
            run_cmd_async(f"{SPAWN_COMMS} nostr keygen {name}", done, timeout=30)
        else:
            dlg.destroy()

    def _nostr_add_relay_dialog(self, btn):
        dlg = Gtk.Dialog(title="Add Relay", parent=self, modal=True)
        dlg.set_default_size(440, 160)
        ca = dlg.get_content_area()
        ca.set_spacing(12); ca.set_margin_start(20); ca.set_margin_end(20)
        ca.set_margin_top(20); ca.set_margin_bottom(20)

        lbl = Gtk.Label(label="Relay URL (SpawnOS device or public relay):")
        lbl.set_xalign(0); ca.pack_start(lbl, False, False, 0)
        entry = Gtk.Entry()
        entry.set_placeholder_text("ws://192.168.1.42:7777  or  wss://relay.damus.io")
        ca.pack_start(entry, False, False, 0)
        hint = Gtk.Label(label="For another SpawnOS device: ws://THEIR-IP:7777")
        hint.get_style_context().add_class("card-sub"); hint.set_xalign(0)
        ca.pack_start(hint, False, False, 0)

        dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dlg.add_button("Add",    Gtk.ResponseType.OK)
        entry.connect("activate", lambda e: dlg.response(Gtk.ResponseType.OK))
        ca.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            url = entry.get_text().strip()
            dlg.destroy()
            if url and (url.startswith("ws://") or url.startswith("wss://")):
                def done(out, ok):
                    self._nostr_refresh()
                    self._show_toast("Relay added!" if ok else f"Error: {out[:80]}")
                run_cmd_async(f"{SPAWN_COMMS} nostr peers add '{url}'", done)
            else:
                self._show_toast("Invalid URL. Must start with ws:// or wss://")
        else:
            dlg.destroy()

    def _nostr_publish(self, btn):
        buf = self._nostr_msg_entry.get_buffer()
        msg = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False).strip()
        if not msg or msg == "What's on your mind?":
            self._nostr_pub_status.set_markup("<span foreground='#f87171'>Enter a message first.</span>")
            return
        # Escape for shell
        msg_safe = msg.replace("'", "'\\''")
        self._nostr_pub_btn.set_sensitive(False)
        self._nostr_pub_btn.set_label("Sending…")
        self._nostr_pub_status.set_text("Publishing…")
        def done(out, ok):
            self._nostr_pub_btn.set_sensitive(True)
            self._nostr_pub_btn.set_label("Publish")
            if ok:
                self._nostr_pub_status.set_markup("<span foreground='#4ade80'>✓ Published!</span>")
                buf.set_text("")
            else:
                self._nostr_pub_status.set_markup(f"<span foreground='#f87171'>Failed: {out[:60]}</span>")
        run_cmd_async(f"{SPAWN_COMMS} nostr publish '{msg_safe}'", done, timeout=30)

