#!/usr/bin/env bash
# =============================================================================
#  spawnkey вЂ” SpawnOS unified CLI
#  Controls Spawn agent, Bitcoin tools, privacy, and system status
#  Alias: sk
# =============================================================================

SPAWN_CONFIG="/etc/spawn/config.yml"
SPAWN_DATA="/home/spawn/.spawn"
SPAWN_VERSION="1.0.0"
SPAWNOS_VERSION="1.0.0"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

banner() {
  echo -e "${CYAN}"
  cat << 'BANNER'
  в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в•— в–€в–€в•—    в–€в–€в•—в–€в–€в–€в•—   в–€в–€в•— в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—
  в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•‘    в–€в–€в•‘в–€в–€в–€в–€в•—  в–€в–€в•‘в–€в–€в•”в•ђв•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќ
  в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘ в–€в•— в–€в–€в•‘в–€в–€в•”в–€в–€в•— в–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—
  в•љв•ђв•ђв•ђв•ђв–€в–€в•‘в–€в–€в•”в•ђв•ђв•ђв•ќ в–€в–€в•”в•ђв•ђв–€в–€в•‘в–€в–€в•‘в–€в–€в–€в•—в–€в–€в•‘в–€в–€в•‘в•љв–€в–€в•—в–€в–€в•‘в–€в–€в•‘   в–€в–€в•‘в•љв•ђв•ђв•ђв•ђв–€в–€в•‘
  в–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘     в–€в–€в•‘  в–€в–€в•‘в•љв–€в–€в–€в•”в–€в–€в–€в•”в•ќв–€в–€в•‘ в•љв–€в–€в–€в–€в•‘в•љв–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в–€в–€в•‘
  в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ     в•љв•ђв•ќ  в•љв•ђв•ќ в•љв•ђв•ђв•ќв•љв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќ
BANNER
  echo -e "  ${BOLD}SpawnOS v${SPAWNOS_VERSION}${NC}${CYAN} вЂ” The Sovereign Swiss Army Knife${NC}"
  echo ""
}

usage() {
  banner
  echo -e "${BOLD}USAGE:${NC} spawnkey <command> [args]"
  echo ""
  echo -e "${BOLD}AGENT:${NC}"
  echo "  agent start|stop|restart|status|logs"
  echo "  agent task <text>       Send a task to Spawn"
  echo ""
  echo -e "${BOLD}BITCOIN TOOLS:${NC}"
  echo "  launch sparrow          Sparrow Wallet (Tor-routed)"
  echo "  launch electrum         Electrum (Tor-routed)"
  echo "  launch liana            Liana Wallet"
  echo "  launch seedsigner       SeedSigner Emulator"
  echo ""
  echo -e "${BOLD}BITCOIN STORAGE:${NC}"
  echo "  bitcoin seed store <n>  Encrypt and store a seed phrase"
  echo "  bitcoin seed list       List stored seeds (names only)"
  echo "  bitcoin seed show <n>   Decrypt and display a seed"
  echo "  bitcoin seed delete <n> Securely shred a seed"
  echo "  bitcoin seed qr <n>     Generate QR for SeedSigner"
  echo "  bitcoin psbt import <f> Import PSBT for signing"
  echo "  bitcoin backup          Encrypted backup of all bitcoin data"
  echo ""
  echo -e "${BOLD}COMMS (offline mesh):${NC}"
  echo "  comms status                Full communications status"
  echo "  comms pair <IP>             Pair with another SpawnOS device"
  echo "  comms nostr keygen          Create Nostr identity"
  echo "  comms nostr relay start     Start local Nostr relay (LAN port 7777)"
  echo "  comms nostr peers add <url> Add a relay"
  echo "  comms nostr publish <msg>   Publish a Nostr note"
  echo "  comms bitchat enable        Enable Bluetooth"
  echo "  comms bitchat scan          Scan for nearby SpawnOS devices"
  echo "  comms whitenoise status     WhiteNoise mesh status"
  echo ""
  echo -e "${BOLD}NODE:${NC}"
  echo "  node setup              Configure pruned Bitcoin Core node"
  echo "  node status             Check node connection"
  echo "  node apply              Re-apply node config to wallets"
  echo ""
  echo -e "${BOLD}PRIVACY:${NC}"
  echo "  tor status|newid"
  echo "  mac randomize"
  echo "  wipe                    Secure wipe session data"
  echo ""
  echo -e "${BOLD}SYSTEM:${NC}"
  echo "  init                    First-time setup"
  echo "  status                  Full system status"
  echo "  config get <key>"
  echo "  config set <key> <val>"
  echo ""
}

check_tor() {
  if systemctl is-active --quiet tor 2>/dev/null; then
    echo -e "${GREEN}вњ“ Tor is running${NC}"
    if torsocks curl -s --max-time 10 https://check.torproject.org/api/ip 2>/dev/null | grep -q '"IsTor":true'; then
      echo -e "${GREEN}вњ“ Traffic is routing through Tor${NC}"
    else
      echo -e "${YELLOW}вљ  Tor running but route check failed${NC}"
    fi
  else
    echo -e "${RED}вњ— Tor is NOT running${NC}"
  fi
}

full_status() {
  banner
  echo -e "${BOLD}=== SpawnOS System Status ===${NC}"
  echo ""
  echo -e "${BOLD}Privacy:${NC}"
  check_tor
  systemctl is-active --quiet spawnos-firewall 2>/dev/null \
    && echo -e "${GREEN}вњ“ Firewall active${NC}" \
    || echo -e "${RED}вњ— Firewall INACTIVE вЂ” WARNING${NC}"
  echo ""
  echo -e "${BOLD}Spawn Agent:${NC}"
  systemctl is-active --quiet spawn 2>/dev/null \
    && echo -e "${GREEN}вњ“ Spawn agent: RUNNING${NC}" \
    || echo -e "${RED}вњ— Spawn agent: STOPPED${NC}"
  echo ""
  echo -e "${BOLD}Bitcoin Tools:${NC}"
  for tool in electrum sparrow liana; do
    ( which "$tool" &>/dev/null || ls /opt/"$tool"/bin/"$tool" &>/dev/null 2>&1 ) \
      && echo -e "${GREEN}вњ“ $tool${NC}" \
      || echo -e "${YELLOW}в—‹ $tool not installed${NC}"
  done
}

init_spawnos() {
  banner
  echo -e "${BOLD}=== SpawnOS First-Time Setup ===${NC}"
  echo ""
  read -p "Enter your Spawn API endpoint (leave blank to set later): " api_endpoint
  if [ -n "$api_endpoint" ]; then
    echo "$api_endpoint" | gpg --symmetric --cipher-algo AES256 -o "$SPAWN_DATA/api.key.gpg" 2>/dev/null
    echo -e "${GREEN}вњ“ API endpoint saved (encrypted)${NC}"
  fi
  echo -e "${GREEN}вњ“ SpawnOS initialized${NC}"
  echo "Run: spawnkey agent start"
}

launch_tool() {
  echo -e "${CYAN}Launching $1 via Tor...${NC}"
  case "$1" in
    sparrow)    torsocks /opt/sparrow/bin/Sparrow & ;;
    electrum)   torsocks electrum --proxy socks5:127.0.0.1:9050 & ;;
    liana)      torsocks /opt/liana/Liana & ;;
    seedsigner) python3 /opt/seedsigner-emulator/src/main.py & ;;
    vscodium)   codium & ;;
    *) echo -e "${RED}Unknown tool: $1${NC}"; exit 1 ;;
  esac
  echo -e "${GREEN}вњ“ $1 launched${NC}"
}

case "$1" in
  agent)
    case "$2" in
      start)   sudo systemctl start spawn   && echo -e "${GREEN}вњ“ Started${NC}" ;;
      stop)    sudo systemctl stop spawn    && echo -e "${GREEN}вњ“ Stopped${NC}" ;;
      restart) sudo systemctl restart spawn && echo -e "${GREEN}вњ“ Restarted${NC}" ;;
      status)  systemctl status spawn --no-pager ;;
      logs)    sudo journalctl -u spawn -f ;;
      task)    shift 2; /usr/local/bin/spawn-client task "$*" ;;
      *)       usage ;;
    esac ;;
  launch)   launch_tool "$2" ;;
  bitcoin)  shift; /usr/local/bin/spawn-bitcoin "$@" ;;
  node)     shift; /usr/local/bin/spawn-node "$@" ;;
  comms)    shift; /usr/local/bin/spawn-comms "$@" ;;
  tor)
    case "$2" in
      status) check_tor ;;
      newid)  sudo systemctl reload tor && echo -e "${GREEN}вњ“ New identity requested${NC}" ;;
      *)      usage ;;
    esac ;;
  mac)
    [ "$2" = "randomize" ] && {
      for iface in $(ip -o link show | awk -F': ' '{print $2}' | grep -v lo); do
        sudo macchanger -r "$iface" 2>/dev/null
      done
      echo -e "${GREEN}вњ“ MAC addresses randomized${NC}"
    } ;;
  wipe)     sudo /usr/local/bin/spawn-wipe ;;
  init)     init_spawnos ;;
  status)   full_status ;;
  config)
    case "$2" in
      get) grep "^  $3:" "$SPAWN_CONFIG" 2>/dev/null || grep "$3:" "$SPAWN_CONFIG" ;;
      set) sudo sed -i "s|$3:.*|$3: $4|" "$SPAWN_CONFIG" ;;
      *)   usage ;;
    esac ;;
  --version|-v) echo "spawnkey v${SPAWN_VERSION} / SpawnOS v${SPAWNOS_VERSION}" ;;
  help|--help|-h|"") usage ;;
  *) echo -e "${RED}Unknown: $1${NC}"; usage; exit 1 ;;
esac
